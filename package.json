{
  "name": "petsphilia-platform",
  "private": true,
  "workspaces": [
    "apps/storefront",
    "apps/backend"
  ],
  "scripts": {
    "dev:storefront": "npm --workspace apps/storefront run dev",
    "dev:backend": "npm --workspace apps/backend run dev",
    "build:storefront": "npm --workspace apps/storefront run build",
    "build:backend": "npm --workspace apps/backend run build",
    "start:storefront": "npm --workspace apps/storefront run start",
    "start:backend": "npm --workspace apps/backend run start"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "ts-node": "^10.9.2"
  }
}
